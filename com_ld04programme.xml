<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
	<name>Lancaster Programme display</name>
	<author>David Johnson</author>
	<creationDate>March 2026</creationDate>
	<copyright>(C) 2026 Ramblers Association</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE.txt</license>
	<authorEmail>ramblers@yasur.uk</authorEmail>
	<authorUrl>ramblers.org.uk</authorUrl>
	<version>0.0.1</version>
	<description>Compnent to edit and display Lancaster Group programme</description>

    <namespace path="src/">LD04\Component\Walks</namespace>

    <files folder="site">
        <folder>forms</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
        <filename>walks.php</filename>
    </files>

    <administration>
        <menu link="index.php?option=com_ld04programme">COM_LD04PROGRAMME_MENU</menu>
        <files folder="admin">
            <filename>access.xml</filename>
            <filename>config.xml</filename>
            <folder>forms</folder>
            <folder>language</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
        </files>
    </administration>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>

    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>        
</extension>